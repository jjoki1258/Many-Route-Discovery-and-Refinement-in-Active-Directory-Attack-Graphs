SEED = 42                                      # 재현성 시드
random.seed(SEED)                               # 파이썬 랜덤 고정
np.random.seed(SEED)                            # 넘파이 랜덤 고정

DOMAIN_NAME = "GHOST.CORP"                     # 테스트 도메인
BASE_SAVE_DIR = "/content/drive/MyDrive/Colab Notebooks/26.2.26  ga test2"  # 사용자 지정 저장 위치
